rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid}/tasks/{taskId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /notes/{noteId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    match /users/{uid}/payments/{paymentId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
